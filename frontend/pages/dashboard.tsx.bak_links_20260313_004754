      <div style={{ color: "#9fb3d1", fontSize: 16, marginBottom: 26 }}>{subtitle}</div>

      <div
        style={{
          border: "1px solid #15305b",
          borderRadius: 20,
          overflow: "hidden",
        }}
      >
        {[
          ["CAGR", formatPct(kpis?.cagr)],
          ["Volatilidade", formatPct(kpis?.vol ?? kpis?.volatility)],
          ["Sharpe", formatNumber(kpis?.sharpe)],
          ["Max Drawdown", formatPct(kpis?.max_drawdown)],
          ["Total Return", formatPct(kpis?.total_return)],
        ].map(([label, value], idx, arr) => (
          <div
            key={label}
            style={{
              display: "flex",
              justifyContent: "space-between",
              gap: 20,
              padding: "22px 24px",
              borderBottom: idx < arr.length - 1 ? "1px solid #10284f" : "none",
            }}
          >
            <div style={{ fontSize: 18 }}>{label}</div>
            <div style={{ fontSize: 18, fontWeight: 700 }}>{value}</div>
          </div>
        ))}
      </div>
    </div>
  );
}

function TabButton({
  active,
  label,
  onClick,
}: {
  active: boolean;
  label: string;
  onClick: () => void;
}) {
  return (
    <button
