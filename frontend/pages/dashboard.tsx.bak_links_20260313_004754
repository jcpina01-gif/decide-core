function safeNumber(value: unknown, fallback = 0): number {
  const n = Number(value);
  return Number.isFinite(n) ? n : fallback;
}

function formatPct(value: unknown, decimals = 2): string {
  const n = safeNumber(value, NaN);
  if (!Number.isFinite(n)) return "—";
  return `${(n * 100).toFixed(decimals)}%`;
}

function formatPctFromPercent(value: unknown, decimals = 2): string {
  const n = safeNumber(value, NaN);
  if (!Number.isFinite(n)) return "—";
  return `${n.toFixed(decimals)}%`;
}

function formatNumber(value: unknown, decimals = 2): string {
  const n = safeNumber(value, NaN);
  if (!Number.isFinite(n)) return "—";
  return n.toFixed(decimals);
}

function formatInteger(value: unknown): string {
  const n = safeNumber(value, NaN);
  if (!Number.isFinite(n)) return "—";
  return Math.round(n).toString();
}

function computeDrawdown(equity: number[]): number[] {
  if (!equity.length) return [];

  let peak = equity[0];
  const out: number[] = [];

  for (let i = 0; i < equity.length; i += 1) {
    const value = safeNumber(equity[i], 0);
    if (value > peak) peak = value;
    out.push(peak > 0 ? value / peak - 1 : 0);
  }

  return out;
}

function computeRollingSharpe(equity: number[], window = 252): Array<number | null> {
  if (!equity.length) return [];

  const returns: number[] = [];
  for (let i = 1; i < equity.length; i += 1) {
    const prev = safeNumber(equity[i - 1], 0);
    const curr = safeNumber(equity[i], 0);
    returns.push(prev > 0 ? curr / prev - 1 : 0);
  }

  const out: Array<number | null> = new Array(equity.length).fill(null);

  for (let i = window; i < returns.length; i += 1) {
    const slice = returns.slice(i - window, i);
    if (!slice.length) continue;

    const mean = slice.reduce((a, b) => a + b, 0) / slice.length;
    const variance = slice.reduce((a, b) => a + (b - mean) ** 2, 0) / slice.length;
    const vol = Math.sqrt(variance);

    out[i] = vol > 0 ? (mean / vol) * Math.sqrt(252) : null;
  }

  return out;
}

function KPIBlock({ title, value }: KPIBlockProps) {
  return (
    <div
      style={{
        background: "#020b24",
        border: "1px solid #15305b",
