}

function monthPointText(p?: MonthPoint): string {
  if (!p || !p.month || p.return_pct === null || p.return_pct === undefined) return "—";
  return `${p.month} (${p.return_pct.toFixed(2)}%)`;
}

export default function DashboardFreezePage() {
  const [activeTab, setActiveTab] = useState<"overview" | "portfolio">("overview");
  const [overview, setOverview] = useState<OverviewResponse | null>(null);
  const [equity, setEquity] = useState<EquityPoint[]>([]);
  const [alpha, setAlpha] = useState<AlphaPoint[]>([]);
  const [rollingSharpe, setRollingSharpe] = useState<RollingSharpePoint[]>([]);
  const [kpis, setKpis] = useState<KpisResponse | null>(null);
  const [portfolio, setPortfolio] = useState<PortfolioResponse | null>(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string>("");

  useEffect(() => {
    let cancelled = false;

    async function load() {
      try {
        setLoading(true);
        setError("");

        const qs = `dataset=${DATASET}&period=${PERIOD}`;

        const [o, e, a, rs, k, p] = await Promise.all([
          fetch(`${API_BASE}/api/dashboard/overview?${qs}`).then((r) => r.json()),
          fetch(`${API_BASE}/api/dashboard/equity?${qs}`).then((r) => r.json()),
          fetch(`${API_BASE}/api/dashboard/alpha?${qs}`).then((r) => r.json()),
          fetch(`${API_BASE}/api/dashboard/rolling_sharpe?${qs}`).then((r) => r.json()),
          fetch(`${API_BASE}/api/dashboard/kpis?${qs}`).then((r) => r.json()),
          fetch(`${API_BASE}/api/portfolio/current`).then((r) => r.json()),
        ]);

        if (cancelled) return;

        setOverview(o);
        setEquity(Array.isArray(e) ? e : []);
        setAlpha(Array.isArray(a) ? a : []);
        setRollingSharpe(Array.isArray(rs) ? rs : []);
        setKpis(k);
        setPortfolio(p);
      } catch (err: any) {
        if (!cancelled) {
          setError(err?.message || "Erro ao carregar dados do dashboard.");
        }
      } finally {
        if (!cancelled) setLoading(false);
      }
    }

    load();

    return () => {
      cancelled = true;
    };
  }, []);

  const allDates = useMemo(() => equity.map((x) => x.date), [equity]);
  const alphaDates = useMemo(() => alpha.map((x) => x.date), [alpha]);
  const rollingDates = useMemo(() => rollingSharpe.map((x) => x.date), [rollingSharpe]);

  const benchmarkSeries = useMemo(() => equity.map((x) => x.benchmark), [equity]);
  const modelSeries = useMemo(() => equity.map((x) => x.overlayed), [equity]);
  const alphaSeries = useMemo(() => alpha.map((x) => x.alpha), [alpha]);
  const rollingSeries = useMemo(() => rollingSharpe.map((x) => x.rolling_sharpe), [rollingSharpe]);

  const modelDrawdown = useMemo(() => computeDrawdown(modelSeries), [modelSeries]);
  const benchDrawdown = useMemo(() => computeDrawdown(benchmarkSeries), [benchmarkSeries]);

  const lastDate = equity.length ? equity[equity.length - 1].date : "—";
  const meta = overview?.meta || kpis?.meta;
  const seriesMeta = overview?.series_meta || kpis?.series_meta;
  const monthly = kpis?.monthly_stats;

  const monthlyModelItems = [
    { label: "Meses positivos", value: monthly ? String(monthly.model.positive_months) : "—" },
    { label: "Meses negativos", value: monthly ? String(monthly.model.negative_months) : "—" },
    { label: "Meses flat", value: monthly ? String(monthly.model.flat_months) : "—" },
    { label: "Melhor mês", value: monthPointText(monthly?.model.best_month) },
    { label: "Pior mês", value: monthPointText(monthly?.model.worst_month) },
    { label: "Média mensal", value: monthly ? pct(monthly.model.average_month_pct) : "—" },
    { label: "Mediana mensal", value: monthly ? pct(monthly.model.median_month_pct) : "—" },
    { label: "Meses comparados", value: monthly ? String(monthly.months_compared) : "—" },
  ];

  const monthlyRelativeItems = [
    { label: "Meses acima do bench", value: monthly ? String(monthly.relative.months_above_benchmark) : "—" },
    { label: "Meses abaixo do bench", value: monthly ? String(monthly.relative.months_below_benchmark) : "—" },
    { label: "Meses iguais ao bench", value: monthly ? String(monthly.relative.months_equal_benchmark) : "—" },
    { label: "Melhor mês de alpha", value: monthPointText(monthly?.relative.best_alpha_month) },
    { label: "Pior mês de alpha", value: monthPointText(monthly?.relative.worst_alpha_month) },
    { label: "Alpha médio mensal", value: monthly ? pct(monthly.relative.average_alpha_month_pct) : "—" },
    { label: "Alpha mediano mensal", value: monthly ? pct(monthly.relative.median_alpha_month_pct) : "—" },
    { label: "Meses comparados", value: monthly ? String(monthly.months_compared) : "—" },
  ];

  return (
    <div style={styles.page}>
      <div style={styles.container}>
        <header style={styles.header}>
          <div>
            <div style={styles.brand}>
              decide<span style={styles.brandAI}>AI</span>
            </div>
            <div style={styles.subtitle}>Dashboard técnico do freeze oficial a 20 anos</div>
          </div>

          <div style={styles.headerMeta}>
            <div style={styles.metaLine}><strong>Strategy:</strong> {meta?.strategy ?? "Global Momentum Equity"}</div>
            <div style={styles.metaLine}><strong>Freeze:</strong> {meta?.freeze ?? "DECIDE_MODEL_V1"}</div>
            <div style={styles.metaLine}><strong>Benchmark:</strong> {meta?.benchmark_name ?? "60/25/10/5 composite"}</div>
            <div style={styles.metaLine}><strong>Período:</strong> {PERIOD}</div>
            <div style={styles.metaLine}><strong>Última data:</strong> {lastDate}</div>
            <div style={styles.metaLine}><strong>Observações:</strong> {meta?.points ?? equity.length}</div>
          </div>
        </header>

        <div style={styles.tabsRow}>
          <button
            type="button"
            onClick={() => setActiveTab("overview")}
            style={activeTab === "overview" ? styles.tabButtonActive : styles.tabButton}
          >
            Visão Geral
          </button>
          <button
            type="button"
            onClick={() => setActiveTab("portfolio")}
            style={activeTab === "portfolio" ? styles.tabButtonActive : styles.tabButton}
          >
            Carteira
          </button>
        </div>

        {loading ? (
          <div style={styles.loadingCard}>A carregar dados do freeze 20Y...</div>
        ) : error ? (
          <div style={styles.errorCard}>{error}</div>
        ) : activeTab === "portfolio" ? (
          <HoldingsTable portfolio={portfolio} />
        ) : (
          <>
            <section style={styles.twoCol}>
              <DetailKpiCard
                title="KPIs Modelo"
                kpis={
                  kpis?.model ?? {
                    total_return_pct: null,
                    annualized_return_pct: null,
                    volatility_pct: null,
                    max_drawdown_pct: null,
                    sharpe: null,
                    last_equity: null,
                  }
                }
                accent="#60a5fa"
              />
              <DetailKpiCard
                title="KPIs Benchmark"
                kpis={
                  kpis?.benchmark ?? {
                    total_return_pct: null,
                    annualized_return_pct: null,
                    volatility_pct: null,
                    max_drawdown_pct: null,
                    sharpe: null,
                    last_equity: null,
                  }
                }
                accent="#cbd5e1"
              />
            </section>

            <section style={styles.twoCol}>
              <MonthlyStatsCard title="Estatística Mensal Modelo" items={monthlyModelItems} />
              <MonthlyStatsCard title="Estatística Mensal Relativa" items={monthlyRelativeItems} />
            </section>

            <SimpleLineChart
              title="Benchmark vs Modelo"
              lines={[
                { name: "Benchmark", values: benchmarkSeries, color: "#94a3b8" },
                { name: "Modelo", values: modelSeries, color: "#60a5fa" },
              ]}
              dates={allDates}
              height={380}
              useLog={true}
              footerLeft={equity.length ? `Início ${equity[0].date} · Base=1.00` : "—"}
              footerRight={equity.length ? `Fim ${equity[equity.length - 1].date} · Dataset=${DATASET}` : "—"}
            />

            <div style={styles.twoCol}>
              <DrawdownChart title="Drawdown Modelo" values={modelDrawdown} dates={allDates} />
              <DrawdownChart title="Drawdown Benchmark" values={benchDrawdown} dates={allDates} />
            </div>

            <SimpleLineChart
              title="Alpha Curve (Modelo / Benchmark)"
              lines={[{ name: "Alpha", values: alphaSeries, color: "#38bdf8" }]}
              dates={alphaDates}
              height={260}
              useLog={false}
              footerLeft={alpha.length ? `Início ${alpha[0].date}` : "—"}
              footerRight={alpha.length ? `Fim ${alpha[alpha.length - 1].date}` : "—"}
            />

            <SimpleLineChart
              title="Rolling Sharpe 3Y"
              lines={[{ name: "Rolling Sharpe", values: rollingSeries, color: "#f59e0b" }]}
              dates={rollingDates}
              height={260}
              useLog={false}
              footerLeft={rollingSharpe.length ? `Início ${rollingSharpe[0].date}` : "—"}
              footerRight={
                rollingSharpe.length ? `Fim ${rollingSharpe[rollingSharpe.length - 1].date}` : "—"
              }
            />

            <section style={styles.infoGrid}>
              <div style={styles.card}>
                <div style={styles.cardTitle}>Estado do dataset</div>
                <div style={styles.infoList}>
                  <div>Dataset fixo: {DATASET}</div>
                  <div>Período fixo: {PERIOD}</div>
                  <div>Fonte: {meta?.source_file ?? "—"}</div>
                  <div>Tipo de origem: {meta?.source_kind ?? "—"}</div>
                  <div>Anos cobertos: {meta?.years_covered ?? "—"}</div>
                  <div>Recommended model key: {seriesMeta?.recommended_model_key ?? "—"}</div>
                </div>
              </div>

              <div style={styles.card}>
                <div style={styles.cardTitle}>Leitura</div>
                <div style={styles.infoList}>
                  <div>A aba Carteira usa /api/portfolio/current</div>
                  <div>Alphabet é agregada quando existirem GOOG + GOOGL</div>
                  <div>Se os pesos mostrados somarem menos de 100%, o residual é mostrado como Hedge/Cash</div>
                  <div>O eixo X usa 10 marcas temporais</div>
                  <div>Todos os gráficos têm mouse over com data e valores</div>
                  <div>Notas: {(seriesMeta?.notes || []).join(" | ") || "—"}</div>
                </div>
              </div>
            </section>
          </>
        )}
      </div>
    </div>
  );
}

