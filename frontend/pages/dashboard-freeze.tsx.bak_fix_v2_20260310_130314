function pct(x: number | null | undefined, digits = 2): string {
  if (x === null || x === undefined || Number.isNaN(x)) return "—";
  return `${x.toFixed(digits)}%`;
}

function pctFromRatio(x: number | null | undefined, digits = 2): string {
  if (x === null || x === undefined || Number.isNaN(x)) return "—";
  return `${(x * 100).toFixed(digits)}%`;
}

function num(x: number | null | undefined, digits = 2): string {
  if (x === null || x === undefined || Number.isNaN(x)) return "—";
  return x.toFixed(digits);
}

function compactNum(x: number | null | undefined): string {
  if (x === null || x === undefined || Number.isNaN(x)) return "—";
  if (Math.abs(x) >= 1000) return x.toFixed(0);
  if (Math.abs(x) >= 100) return x.toFixed(0);
  if (Math.abs(x) >= 10) return x.toFixed(1);
  return x.toFixed(2);
}

function getSharedRange(seriesList: Array<Array<number | null>>, useLog = false): { min: number; max: number } {
  const allValues = seriesList.flat().filter((v): v is number => v !== null && Number.isFinite(v));

  if (!allValues.length) {
    return { min: 0, max: 1 };
  }

  let working = allValues;

  if (useLog) {
    working = allValues
      .map((v) => (v > 0 ? Math.log(v) : null))
      .filter((v): v is number => v !== null && Number.isFinite(v));
    if (!working.length) {
      return { min: 0, max: 1 };
    }
  }

  let min = Math.min(...working);
  let max = Math.max(...working);

  if (min === max) {
    min = min - 1;
    max = max + 1;
  }

  return { min, max };
}

function buildLinePathWithRange(
  values: Array<number | null>,
  width: number,
  height: number,
  min: number,
  max: number,
  padLeft = 54,
  padRight = 12,
  padTop = 12,
  padBottom = 28,
  useLog = false
): string {
  const clean = values.map((v) => {
    if (!Number.isFinite(v as number)) return null;
    const n = v as number;
    if (useLog) {
      if (n <= 0) return null;
      return Math.log(n);
    }
    return n;
  });

  const range = max - min || 1;
  const innerW = width - padLeft - padRight;
  const innerH = height - padTop - padBottom;

  let path = "";
  let started = false;

  clean.forEach((v, i) => {
    const x = padLeft + (i / Math.max(clean.length - 1, 1)) * innerW;

    if (v === null) {
      started = false;
      return;
    }

    const y = padTop + innerH - ((v - min) / range) * innerH;
    path += `${started ? " L" : "M"} ${x.toFixed(2)} ${y.toFixed(2)}`;
    started = true;
  });

  return path.trim();
}

function buildAreaPath(
  values: Array<number | null>,
  width: number,
  height: number,
  padLeft = 54,
  padRight = 12,
  padTop = 12,
  padBottom = 28
): string {
  const clean = values.map((v) => (Number.isFinite(v as number) ? (v as number) : null));
  const finite = clean.filter((v): v is number => v !== null);

  if (!finite.length) return "";

  const min = Math.min(...finite);
  const max = Math.max(...finite);
  const range = max - min || 1;

  const innerW = width - padLeft - padRight;
  const innerH = height - padTop - padBottom;
  const bottomY = height - padBottom;

  const points = clean
    .map((v, i) => {
      if (v === null) return null;
      const x = padLeft + (i / Math.max(clean.length - 1, 1)) * innerW;
      const y = padTop + innerH - ((v - min) / range) * innerH;
      return { x, y };
    })
    .filter((p): p is { x: number; y: number } => p !== null);

  if (!points.length) return "";

  const top = points
    .map((p, i) => `${i === 0 ? "M" : "L"} ${p.x.toFixed(2)} ${p.y.toFixed(2)}`)
    .join(" ");

  const last = points[points.length - 1];
  const first = points[0];

  return `${top} L ${last.x.toFixed(2)} ${bottomY.toFixed(2)} L ${first.x.toFixed(
    2
  )} ${bottomY.toFixed(2)} Z`;
}

function yTickLabel(value: number, useLog: boolean, isPercentAxis = false): string {
  const original = useLog ? Math.exp(value) : value;
  if (isPercentAxis) return `${(original * 100).toFixed(0)}%`;
  return compactNum(original);
}

function xTickLabel(date: string): string {
  if (!date) return "";
  return date.slice(0, 4);
}

function getTenTickIndexes(length: number): number[] {
  if (length <= 1) return [0];
  const count = Math.min(10, length);
  const idxs = new Set<number>();
  for (let i = 0; i < count; i += 1) {
    const idx = Math.round((i * (length - 1)) / Math.max(count - 1, 1));
    idxs.add(idx);
  }
  return Array.from(idxs).sort((a, b) => a - b);
}

function ChartTooltip(props: {
  x: number;
  y: number;
  date: string;
  rows: TooltipRow[];
  width?: number;
}) {
  const boxWidth = props.width ?? 190;
  const rowHeight = 18;
  const headerHeight = 20;
  const boxHeight = headerHeight + props.rows.length * rowHeight + 12;

  return (
    <g transform={`translate(${props.x}, ${props.y})`}>
      <rect
        x="0"
        y="0"
        width={boxWidth}
        height={boxHeight}
        rx="10"
        fill="rgba(7,12,22,0.96)"
        stroke="rgba(255,255,255,0.12)"
      />
      <text x="10" y="16" fill="#ffffff" fontSize="12" fontWeight="700">
        {props.date}
      </text>
      {props.rows.map((row, i) => (
        <g key={`${row.label}-${i}`} transform={`translate(10, ${28 + i * rowHeight})`}>
          <circle cx="4" cy="5" r="4" fill={row.color} />
          <text x="14" y="9" fill="#cdd8e8" fontSize="11">
            {row.label}: {row.value}
          </text>
        </g>
      ))}
    </g>
  );
}

function SimpleLineChart(props: {
  title: string;
  lines: Array<{ name: string; values: Array<number | null>; color: string }>;
  dates?: string[];
  height?: number;
  footerLeft?: string;
  footerRight?: string;
  useLog?: boolean;
  isPercentAxis?: boolean;
}) {
  const width = 960;
  const height = props.height ?? 300;
  const useLog = props.useLog ?? false;
  const isPercentAxis = props.isPercentAxis ?? false;
  const padLeft = 54;
  const padRight = 12;
  const padTop = 12;
  const padBottom = 28;

  const [hoverIndex, setHoverIndex] = useState<number | null>(null);

  const sharedRange = getSharedRange(
    props.lines.map((line) => line.values),
    useLog
  );

  const yTicks = [0, 1, 2, 3].map((i) => {
    const ratio = i / 3;
    const value = sharedRange.max - ratio * (sharedRange.max - sharedRange.min);
    const innerH = height - padTop - padBottom;
    const y = padTop + ratio * innerH;
    return { y, value };
  });

  const dates = props.dates ?? [];
  const xTickIndexes = getTenTickIndexes(dates.length);
  const innerW = width - padLeft - padRight;

  const hoverX =
    hoverIndex === null ? null : padLeft + (hoverIndex / Math.max(dates.length - 1, 1)) * innerW;

  const tooltipRows: TooltipRow[] =
    hoverIndex === null
      ? []
      : props.lines.map((line) => {
          const raw = line.values[hoverIndex];
          return {
            label: line.name,
            value: isPercentAxis ? pctFromRatio(raw) : compactNum(raw),
            color: line.color,
          };
        });

  return (
    <div style={styles.card}>
      <div style={styles.cardHeaderRow}>
        <div style={styles.cardTitle}>{props.title}</div>
        <div style={styles.legendRow}>
          {props.lines.map((line) => (
            <div key={line.name} style={styles.legendItem}>
              <span style={{ ...styles.legendDot, background: line.color }} />
              <span>{line.name}</span>
            </div>
          ))}
          <div style={styles.scaleBadge}>{useLog ? "Escala log" : "Escala linear"}</div>
        </div>
      </div>

      <div style={{ width: "100%", overflowX: "auto" }}>
        <svg
          viewBox={`0 0 ${width} ${height}`}
          style={{ width: "100%", height }}
          preserveAspectRatio="none"
          onMouseLeave={() => setHoverIndex(null)}
          onMouseMove={(e) => {
            const svg = e.currentTarget;
            const rect = svg.getBoundingClientRect();
            const xPx = ((e.clientX - rect.left) / rect.width) * width;
            const boundedX = Math.min(Math.max(xPx, padLeft), width - padRight);
            const idx = Math.round(((boundedX - padLeft) / innerW) * Math.max(dates.length - 1, 0));
            setHoverIndex(Math.min(Math.max(idx, 0), Math.max(dates.length - 1, 0)));
          }}
        >
          <rect x="0" y="0" width={width} height={height} fill="transparent" />

          {yTicks.map((tick, i) => (
            <g key={i}>
              <line
                x1={padLeft}
                y1={tick.y}
                x2={width - padRight}
                y2={tick.y}
                stroke="rgba(255,255,255,0.08)"
                strokeWidth="1"
              />
              <text
                x={padLeft - 8}
                y={tick.y + 4}
                fill="#8ea4c7"
                fontSize="11"
                textAnchor="end"
              >
                {yTickLabel(tick.value, useLog, isPercentAxis)}
              </text>
            </g>
          ))}

          <line
            x1={padLeft}
            y1={padTop}
            x2={padLeft}
            y2={height - padBottom}
            stroke="rgba(255,255,255,0.08)"
            strokeWidth="1"
          />
          <line
            x1={padLeft}
            y1={height - padBottom}
            x2={width - padRight}
            y2={height - padBottom}
            stroke="rgba(255,255,255,0.08)"
            strokeWidth="1"
          />

          {xTickIndexes.map((idx, i) => {
            const x = padLeft + (idx / Math.max(dates.length - 1, 1)) * innerW;
            return (
              <g key={i}>
                <line
                  x1={x}
                  y1={height - padBottom}
                  x2={x}
                  y2={height - padBottom + 4}
                  stroke="rgba(255,255,255,0.20)"
                  strokeWidth="1"
                />
                <text
                  x={x}
                  y={height - 8}
                  fill="#8ea4c7"
                  fontSize="11"
                  textAnchor="middle"
                >
                  {xTickLabel(dates[idx])}
                </text>
              </g>
            );
          })}

          {hoverX !== null && (
            <line
              x1={hoverX}
              y1={padTop}
              x2={hoverX}
              y2={height - padBottom}
              stroke="rgba(255,255,255,0.25)"
              strokeWidth="1"
              strokeDasharray="4 4"
            />
          )}

          {props.lines.map((line) => (
            <path
              key={line.name}
              d={buildLinePathWithRange(
                line.values,
                width,
                height,
                sharedRange.min,
                sharedRange.max,
                padLeft,
                padRight,
                padTop,
                padBottom,
                useLog
              )}
              fill="none"
              stroke={line.color}
              strokeWidth="2.2"
              strokeLinecap="round"
              strokeLinejoin="round"
            />
          ))}

          {hoverIndex !== null && dates[hoverIndex] && (
            <ChartTooltip
              x={Math.min(Math.max((hoverX ?? 0) + 10, 10), width - 210)}
              y={18}
              date={dates[hoverIndex]}
              rows={tooltipRows}
            />
          )}
        </svg>
      </div>

      <div style={styles.chartFooter}>
        <div>{props.footerLeft ?? "—"}</div>
        <div>{props.footerRight ?? "—"}</div>
      </div>
    </div>
  );
}

function DrawdownChart(props: { title: string; values: Array<number | null>; dates?: string[] }) {
  const width = 960;
  const height = 220;
  const vals = props.values;
  const dates = props.dates ?? [];
  const padLeft = 54;
  const padRight = 12;
  const padTop = 12;
  const padBottom = 28;

  const [hoverIndex, setHoverIndex] = useState<number | null>(null);

  const finiteVals = vals.filter((v): v is number => v !== null && Number.isFinite(v));
  const current = finiteVals.length ? finiteVals[finiteVals.length - 1] : null;
  const minimum = finiteVals.length ? Math.min(...finiteVals) : null;

  const minForChart = finiteVals.length ? Math.min(...finiteVals, -1) : -1;
  const maxForChart = finiteVals.length ? Math.max(...finiteVals, 0) : 0;

  const yTicks = [0, 1, 2, 3].map((i) => {
    const ratio = i / 3;
    const value = maxForChart - ratio * (maxForChart - minForChart);
    const innerH = height - padTop - padBottom;
    const y = padTop + ratio * innerH;
    return { y, value };
  });

  const xTickIndexes = getTenTickIndexes(dates.length);
  const innerW = width - padLeft - padRight;
  const hoverX =
    hoverIndex === null ? null : padLeft + (hoverIndex / Math.max(dates.length - 1, 1)) * innerW;

  return (
    <div style={styles.card}>
      <div style={styles.cardTitle}>{props.title}</div>
      <div style={{ width: "100%", overflowX: "auto" }}>
        <svg
          viewBox={`0 0 ${width} ${height}`}
          style={{ width: "100%", height }}
          preserveAspectRatio="none"
          onMouseLeave={() => setHoverIndex(null)}
          onMouseMove={(e) => {
            const svg = e.currentTarget;
            const rect = svg.getBoundingClientRect();
            const xPx = ((e.clientX - rect.left) / rect.width) * width;
            const boundedX = Math.min(Math.max(xPx, padLeft), width - padRight);
            const idx = Math.round(((boundedX - padLeft) / innerW) * Math.max(dates.length - 1, 0));
            setHoverIndex(Math.min(Math.max(idx, 0), Math.max(dates.length - 1, 0)));
          }}
        >
          <rect x="0" y="0" width={width} height={height} fill="transparent" />

          {yTicks.map((tick, i) => (
            <g key={i}>
              <line
                x1={padLeft}
                y1={tick.y}
                x2={width - padRight}
                y2={tick.y}
                stroke="rgba(255,255,255,0.08)"
                strokeWidth="1"
              />
              <text
                x={padLeft - 8}
                y={tick.y + 4}
                fill="#8ea4c7"
                fontSize="11"
                textAnchor="end"
              >
                {pctFromRatio(tick.value, 0)}
              </text>
            </g>
          ))}

          <line
            x1={padLeft}
            y1={padTop}
            x2={padLeft}
            y2={height - padBottom}
            stroke="rgba(255,255,255,0.08)"
            strokeWidth="1"
          />
          <line
            x1={padLeft}
            y1={height - padBottom}
            x2={width - padRight}
            y2={height - padBottom}
            stroke="rgba(255,255,255,0.08)"
            strokeWidth="1"
          />

          {xTickIndexes.map((idx, i) => {
            const x = padLeft + (idx / Math.max(dates.length - 1, 1)) * innerW;
            return (
              <g key={i}>
                <line
                  x1={x}
                  y1={height - padBottom}
                  x2={x}
                  y2={height - padBottom + 4}
                  stroke="rgba(255,255,255,0.20)"
                  strokeWidth="1"
                />
                <text
                  x={x}
                  y={height - 8}
                  fill="#8ea4c7"
                  fontSize="11"
                  textAnchor="middle"
                >
                  {xTickLabel(dates[idx])}
                </text>
              </g>
            );
          })}

          {hoverX !== null && (
            <line
              x1={hoverX}
              y1={padTop}
              x2={hoverX}
              y2={height - padBottom}
              stroke="rgba(255,255,255,0.25)"
              strokeWidth="1"
              strokeDasharray="4 4"
            />
          )}

          <path
            d={buildAreaPath(vals, width, height, padLeft, padRight, padTop, padBottom)}
            fill="rgba(59,130,246,0.18)"
          />
          <path
            d={buildLinePathWithRange(
              vals,
              width,
              height,
              minForChart,
              maxForChart,
              padLeft,
              padRight,
              padTop,
              padBottom
            )}
            fill="none"
            stroke="#60a5fa"
            strokeWidth="2"
            strokeLinecap="round"
            strokeLinejoin="round"
          />

          {hoverIndex !== null && dates[hoverIndex] && (
            <ChartTooltip
              x={Math.min(Math.max((hoverX ?? 0) + 10, 10), width - 210)}
              y={18}
              date={dates[hoverIndex]}
              rows={[
                {
                  label: "Drawdown",
                  value: pctFromRatio(vals[hoverIndex]),
                  color: "#60a5fa",
                },
              ]}
              width={175}
            />
          )}
        </svg>
      </div>
      <div style={styles.chartFooter}>
        <div>Atual {pctFromRatio(current)}</div>
        <div>Mín {pctFromRatio(minimum)}</div>
      </div>
    </div>
  );
}

function computeDrawdown(series: Array<number | null>): Array<number | null> {
  let peak = -Infinity;
  return series.map((v) => {
    if (v === null || !Number.isFinite(v)) return null;
    peak = Math.max(peak, v);
    if (!Number.isFinite(peak) || peak === 0) return null;
    return v / peak - 1;
  });
}

