function HoldingsTable(props: { portfolio: PortfolioResponse | null }) {
  const basePositions = props.portfolio?.positions ?? [];

  const shownExposure = basePositions.reduce((acc, p) => {
    const w = p.weight ?? 0;
    return acc + w;
  }, 0);

  const residual = Math.max(0, 100 - shownExposure);
  const total = shownExposure + residual;

  const positions =
    residual > 0.0001
      ? [
          ...basePositions,
          {
            ticker: "HEDGE/CASH",
            short_name: "Hedge / Cash / Overlay",
            weight: Number(residual.toFixed(2)),
            country: "—",
          },
        ]
      : basePositions;

  return (
    <div style={styles.card}>
      <div style={styles.cardHeaderRow}>
        <div style={styles.cardTitle}>Carteira Atual</div>
        <div style={styles.legendRow}>
