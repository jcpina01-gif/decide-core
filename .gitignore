node_modules/
**/node_modules/

# Python (inclui .venv311, .venv, etc.)
.venv*/
**/.venv*/
venv/
ENV/

# Dados locais / backups enormes
.data/
_ARCHIVE_BACKUPS/

__pycache__/
*.py[cod]
.pytest_cache/

# Snapshots / cópias locais (muito grandes)
backend/RELEASES/
backend_CORRUPTED*/

# Segredos e ambiente local
.env
.env.local
**/.env.local

# Next (build)
.next/
next-cache/
**/next-cache/

# Raiz do clone: só README + frontend/ são do projeto; o resto são cópias locais / notas / logs
/*
!/.gitignore
!/README.md
!/frontend/
# API FastAPI / Cloud Run: versionar o mínimo para `main:app` + Docker (`COPY backend/`).
# O resto da pasta backend/ (milhares de .py de research, BAK, tools, logs) continua ignorado.
!/backend/
/backend/*
!/backend/main.py
!/backend/app_main.py
!/backend/app_shared.py
!/backend/core.py
!/backend/engine_v2.py
!/backend/engine_entrypoint.py
!/backend/engine_research_v2_constrained.py
!/backend/ib_socket_env.py
!/backend/ib_insync_thread_loop.py
!/backend/ibkr_paper_checks.py
!/backend/ibkr_internal_routing.py
!/backend/server.py
!/backend/requirements.txt
# Rotas incluídas em app_main (uvicorn main:app)
!/backend/routers/
/backend/routers/*
!/backend/routers/__init__.py
!/backend/routers/run_model.py
!/backend/routers/send_orders.py
!/backend/routers/paper_demo_orders.py
!/backend/routers/ibkr_snapshot.py
!/backend/routers/performance.py
!/backend/routers/flatten_portfolio.py
!/backend/routers/cancel_open_orders_paper.py
!/backend/routers/sync_paper_exec_lines.py
# Pipeline KPI: regenerar freeze / sync preços / tarefa diária (whitelisted)
!/backend/scripts/
/backend/scripts/*
!/backend/scripts/regenerate_smooth_freeze_outputs.py
!/backend/scripts/update_prices_close_yfinance.py
!/backend/scripts/run_daily_freeze_update.ps1
!/backend/scripts/restart_decide_kpi_server.ps1
!/backend/scripts/register_windows_daily_freeze_task.ps1
!/backend/scripts/sync_prices_close_between_repos.ps1
!/backend/scripts/export_smooth_freeze_from_v5.py
!/backend/scripts/run_cap15_window_mar2006_anchor.py
# Preços para o motor (run-model). CSV podem ser grandes — Git LFS se necessário.
!/backend/data/
/backend/data/*
!/backend/data/prices_close.csv
!/backend/data/prices_close_20y_global_index_proxy_from_tws.csv
# Histórico de recomendações (`/api/client/recommendations-history`, embed histórico)
!/backend/data/weights_by_rebalance.csv
!/backend/data/weights_by_rebalance_full.csv
!/backend/data/weights_by_rebalance_normalized_long.csv
/backend/data/backups/
# KPI Flask (iframe do client-dashboard) — ficheiro na raiz; dados em freeze/ (deploy separado ou disco)
!/kpi_server.py
!/requirements-kpi.txt
# Permite `pip install -r requirements.txt` no Render (serviço KPI na raiz); conteúdo = -r requirements-kpi.txt
!/requirements.txt

# Freeze mínimo CAP15 (V5_V2_3_SMOOTH): liquidez por data + KPIs no histórico (`recommendations-history.ts`)
!/freeze/
/freeze/*
!/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/
/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/*
!/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/model_outputs/
/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/model_outputs/*
!/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/model_outputs/cash_sleeve_daily.csv
!/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/model_outputs/v5_kpis.json
!/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/model_outputs/model_equity_final_20y.csv
# KPI embed / Flask: sem estes ficheiros no repo, o Render não os recebe e o kpi_server cai em
# raw_eq=model_eq ou margem em falta → três cartões com os mesmos KPIs.
!/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/model_outputs/model_equity_theoretical_20y.csv
!/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/model_outputs/benchmark_equity_final_20y.csv
!/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/model_outputs/model_equity_final_20y_margin.csv
!/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/model_outputs/model_equity_final_20y_moderado_margin.csv
!/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/model_outputs/model_equity_final_20y_conservador_margin.csv
!/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/model_outputs/model_equity_final_20y_dinamico_margin.csv
!/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/model_outputs/model_equity_final_20y_moderado.csv
!/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/model_outputs/model_equity_final_20y_conservador.csv
!/freeze/DECIDE_MODEL_V5_V2_3_SMOOTH/model_outputs/model_equity_final_20y_dinamico.csv
